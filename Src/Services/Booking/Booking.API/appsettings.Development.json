{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft": "Debug",
      "Microsoft.AspNetCore": "Debug",
      "Booking": "Debug"
    }
  },
  "ConnectionStrings": {
    "BookingConnection": "Server=(localdb)\\MSSQLLocalDB;Database=BookingDb;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true",
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=BookingDb;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },
  "AllowedHosts": "*",
  "AppSettings": {
    "HoldDurationMinutes": 10,
    "CleanupIntervalMinutes": 5,
    "MaxRequestsPerMinute": 100,
    "MaxHoldsPerMinute": 10
  }
}
